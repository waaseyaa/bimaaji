#!/usr/bin/env php
<?php

declare(strict_types=1);

use Waaseyaa\Bimaaji\Graph\ApplicationGraphGenerator;
use Waaseyaa\Foundation\Kernel\AbstractKernel;
use Waaseyaa\Foundation\Kernel\HttpKernel;
use Waaseyaa\Foundation\ServiceProvider\ServiceProvider;

$projectRoot = getcwd();
if ($projectRoot === false) {
    fwrite(STDERR, "Unable to resolve current working directory.\n");
    exit(1);
}

$autoloadPath = $projectRoot . '/vendor/autoload.php';
if (!is_file($autoloadPath)) {
    fwrite(STDERR, "Unable to locate vendor/autoload.php from current working directory.\n");
    exit(1);
}

require $autoloadPath;

$envPath = $projectRoot . '/.env';
if (is_file($envPath)) {
    (new \Symfony\Component\Dotenv\Dotenv())->loadEnv($envPath);
}

$kernel = new HttpKernel($projectRoot);
$boot = new ReflectionMethod(AbstractKernel::class, 'boot');
$boot->setAccessible(true);
$boot->invoke($kernel);

foreach ($kernel->getProviders() as $provider) {
    if (!$provider instanceof ServiceProvider) {
        continue;
    }

    if (!isset($provider->getBindings()[ApplicationGraphGenerator::class])) {
        continue;
    }

    $generator = $provider->resolve(ApplicationGraphGenerator::class);
    if (!$generator instanceof ApplicationGraphGenerator) {
        fwrite(STDERR, "ApplicationGraphGenerator binding did not resolve correctly.\n");
        exit(1);
    }

    echo json_encode(
        $generator->generate()->toArray(),
        JSON_UNESCAPED_SLASHES | JSON_INVALID_UTF8_SUBSTITUTE | JSON_THROW_ON_ERROR,
    );
    echo "\n";
    exit(0);
}

fwrite(STDERR, "No provider registered an ApplicationGraphGenerator binding.\n");
exit(1);
