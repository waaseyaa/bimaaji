{
    "name": "waaseyaa/bimaaji",
    "description": "Bimaaji — application graph introspection and agent-safe mutation for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "nikic/php-parser": "^5.0",
        "php": ">=8.5",
        "symfony/routing": "^7.0",
        "waaseyaa/entity": "^0.1.0-alpha.272",
        "waaseyaa/foundation": "^0.1.0-alpha.272",
        "waaseyaa/routing": "^0.1.0-alpha.272"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "waaseyaa/cli": "Enables the graph:dump and bimaaji:install command integrations."
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Bimaaji\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Bimaaji\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Bimaaji\\BimaajiServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../routing"
        }
    ]
}
